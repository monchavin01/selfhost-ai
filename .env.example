# Copy to .env and fill in
# ===== REQUIRED =====
HF_TOKEN=hf_xxxxx_from_huggingface.co/settings/tokens
LITELLM_MASTER_KEY=sk-change-this-to-a-long-random-string
PG_PASSWORD=change-this-password
# Redis password for LiteLLM cache (generate: openssl rand -hex 24)
REDIS_PASSWORD=change-this-password
NEXTAUTH_SECRET=change-this-random-string
LANGFUSE_SALT=change-this-random-string
# Generate: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=change-this-32-byte-hex-string

# Langfuse dedicated backing services
LANGFUSE_PG_PASSWORD=change-this-password
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=change-this-password
LANGFUSE_REDIS_AUTH=change-this-password
LANGFUSE_MINIO_USER=minio
LANGFUSE_MINIO_PASSWORD=change-this-password

# Langfuse: pre-provision the first admin account (fill before first boot)
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=My Org
LANGFUSE_INIT_PROJECT_ID=main
LANGFUSE_INIT_PROJECT_NAME=Main
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=change-this-password

# Set to false after creating all user accounts to prevent new self-registrations
LANGFUSE_ENABLE_SIGNUP=true

# Admin-only token (distinct from LITELLM_MASTER_KEY). Used by the ./scripts/admin
# CLI and anyone calling :8080 directly. If a user key leaks, admin control is
# unaffected because this is a separate credential.
ADMIN_TOKEN=change-this-to-a-long-random-string

# ===== OPTIONAL =====
# For coding-smart (free NVIDIA Nemotron 3 Super 120B via OpenRouter).
# Sign up at https://openrouter.ai and generate a key. Leave as "dummy" to disable.
OPENROUTER_API_KEY=dummy

# Langfuse keys. Create them in the Langfuse UI at http://localhost:3000 after
# first launch. Leave empty to skip trace logging.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
